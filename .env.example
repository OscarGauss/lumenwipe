# Public app URL (used for sitemap, robots.txt, and structured data)
NEXT_PUBLIC_APP_URL=

# Stellar RPC endpoints (no Horizon)
NEXT_PUBLIC_STELLAR_RPC_MAINNET=https://mainnet.stellar.validationcloud.io/v1/YOUR_KEY_HERE
NEXT_PUBLIC_STELLAR_RPC_TESTNET=https://soroban-testnet.stellar.org

# StellarExpert API base URLs (no key required)
# These are hardcoded in config/networks.ts - override here only for testing
# NEXT_PUBLIC_SE_API_BASE_MAINNET=https://api.stellar.expert/explorer/public
# NEXT_PUBLIC_SE_API_BASE_TESTNET=https://api.stellar.expert/explorer/testnet

# Vercel KV (Redis) - required for the merge counter
# Provision via: vercel link && vercel env pull
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Shared mediator account - required only for merges to exchanges that don't
# support ACCOUNT_MERGE. Generate a keypair, fund the account once (it keeps a
# ~1 XLM base reserve that is reused for everyone), put the PUBLIC key below
# (exposed to the client) and the SECRET on the server only (never prefixed
# with NEXT_PUBLIC_). Without these, exchange destinations cannot be processed.
NEXT_PUBLIC_MEDIATOR_PUBLIC_MAINNET=
NEXT_PUBLIC_MEDIATOR_PUBLIC_TESTNET=
MEDIATOR_SECRET_MAINNET=
MEDIATOR_SECRET_TESTNET=

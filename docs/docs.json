{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "LumenWipe",
  "colors": {
    "primary": "#00B0F0",
    "light": "#4DC4F5",
    "dark": "#00B0F0"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "decoration": "grid",
    "color": {
      "dark": "#07070B",
      "light": "#FFFFFF"
    }
  },
  "fonts": {
    "heading": {
      "family": "Bricolage Grotesque",
      "weight": 700
    },
    "body": {
      "family": "Manrope"
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://lumenwipe.com"
  },
  "navigation": {
    "groups": [
      {
        "group": "Documentation",
        "pages": ["index", "executive-summary", "architecture", "community-and-communications"]
      },
      {
        "group": "Use cases",
        "pages": [
          "use-cases/overview",
          "use-cases/individuals",
          "use-cases/wallets-and-exchanges",
          "use-cases/embedded-wallet-platforms",
          "use-cases/businesses-and-operations"
        ]
      }
    ]
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "chatgpt", "claude", "mcp"],
    "display": "header"
  },
  "navbar": {
    "links": [
      {
        "label": "Open the app",
        "href": "https://lumenwipe.com/mainnet",
        "icon": "arrow-up-right-from-square"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/LumenWipe/lumenwipe",
        "icon": "github"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Executive summary",
      "href": "/executive-summary"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/LumenWipe/lumenwipe"
    }
  },
  "seo": {
    "metatags": {
      "canonical": "https://docs.lumenwipe.com"
    }
  }
}

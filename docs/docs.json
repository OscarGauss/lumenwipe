{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "LumenWipe",
  "colors": {
    "primary": "#4F46E5",
    "light": "#818CF8",
    "dark": "#4338CA"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://lumenwipe.com"
  },
  "fonts": {
    "family": "Inter"
  },
  "navigation": {
    "groups": [
      {
        "group": "Documentation",
        "pages": [
          "index",
          "executive-summary",
          "architecture",
          "rfp-compliance",
          "community-and-communications"
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "assistant",
      "chatgpt",
      "claude",
      "mcp"
    ],
    "display": "header"
